# =========================
# Core application
# =========================
APP_NAME=V2T
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production
BASE_URL=https://v2t.example.com

# =========================
# Telegram (required)
# =========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://v2t.example.com/webhook/telegram

# =========================
# Google OAuth (required)
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://v2t.example.com/auth/google/callback
GOOGLE_NOTES_MODE=docs
GOOGLE_DOCS_DOCUMENT_ID=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB_NAME=Sheet1

# =========================
# PostgreSQL (required)
# =========================
POSTGRES_DB=v2t
POSTGRES_USER=v2t
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://v2t:change-me@postgres:5432/v2t

# =========================
# Redis / Celery (required)
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =========================
# STT (required: choose provider and set keys for used providers)
# =========================
STT_PROVIDER=vosk
STT_FALLBACK_PROVIDERS=faster_whisper,google,yandex
STT_DEFAULT_LANGUAGE=ru-RU
STT_VOSK_MODEL_PATH=/models/vosk
STT_FASTER_WHISPER_MODEL_SIZE=small
STT_FASTER_WHISPER_DEVICE=cpu
STT_GOOGLE_API_KEY=
STT_YANDEX_API_KEY=
STT_YANDEX_FOLDER_ID=

# =========================
# Payments (required)
# =========================
PAYMENTS_PROVIDER=yookassa
PAYMENTS_YOOKASSA_WEBHOOK_SECRET=
PAYMENTS_CLOUDPAYMENTS_SECRET=
PAYMENTS_ROBOKASSA_PASSWORD2=

# =========================
# Tariffs (required)
# =========================
TARIFF_BASIC_MAX_VOICE_SECONDS=300
TARIFF_PRO_MAX_VOICE_SECONDS=1800
TARIFF_BASIC_PRICE_RUB=0
TARIFF_PRO_PRICE_RUB=499

# =========================
# Storage
# =========================
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/tmp/v2t_storage
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

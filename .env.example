# App
APP_NAME=V2T
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production
BASE_URL=https://v2t.example.com

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://v2t.example.com/webhook/telegram

# PostgreSQL
POSTGRES_DB=v2t
POSTGRES_USER=v2t
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://v2t:change-me@postgres:5432/v2t

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://v2t.example.com/auth/google/callback

# STT providers
STT_PROVIDER=vosk
STT_FALLBACK_PROVIDERS=faster_whisper,google,yandex
STT_DEFAULT_LANGUAGE=ru-RU
STT_VOSK_MODEL_PATH=/models/vosk
STT_FASTER_WHISPER_MODEL_SIZE=small
STT_FASTER_WHISPER_DEVICE=cpu
STT_GOOGLE_API_KEY=
STT_YANDEX_API_KEY=
STT_YANDEX_FOLDER_ID=

# Payments (provider-agnostic)
PAYMENTS_PROVIDER=stripe
PAYMENTS_WEBHOOK_SECRET=
PAYMENTS_SUCCESS_URL=https://v2t.example.com/payments/success
PAYMENTS_CANCEL_URL=https://v2t.example.com/payments/cancel
PAYMENTS_CURRENCY=RUB
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Tariffs / limits
TARIFF_BASIC_MAX_VOICE_SECONDS=300
TARIFF_PRO_MAX_VOICE_SECONDS=1800
TARIFF_BASIC_PRICE_RUB=0
TARIFF_PRO_PRICE_RUB=499

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/tmp/v2t_storage
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
